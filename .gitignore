    <div class='auth-overlay-modal' id='loginModalOverlay'>

        <div id='auth-module'>

            <div class='card'>

                <div class='logo-section'>

                   <h1>Jannatul</h1>

                </div>

                <div id='login-section'>

                    <h3 style='margin: 0 0 15px 0; font-weight: normal; font-size: 18px; color:#333;'>Log in</h3>

                    <form onsubmit='return false;'>

                        <input id='lEmail' placeholder='Email address' required='required' type='text'/>

                        <input id='lPass' placeholder='Password' required='required' type='password'/>

                        <button class='btn-blue' onclick='handleLogin()'>Log In</button>

                    </form>

                    

                    <span class='forgot-link' onclick='resetPasswordEmail()'>Forgotten account?</span>

                    

                    <div class='divider'/>

                    

                    <button class='btn-green' onclick='showSignup()'>Create new account</button>

                    </div>

                <div id='signup-section'>

                    <button class='btn-white' onclick='showLogin()' style='width:auto; margin-bottom:10px;'>&#8592; Back</button>

                    <h2 style='font-size: 20px; color: #333; margin-bottom: 5px;'>Create account</h2>

                    <div class='divider'/>

                    <form onsubmit='return false;'>

                        <div style='text-align: center; margin-bottom: 15px;'>

                            <img alt='Profile Preview' id='photo-preview' src='https://via.placeholder.com/80?text=Photo'/>

                            <input accept='image/*' id='photo-input' onchange='previewPhoto(event)' style='display: none;' type='file'/>

                            <label for='photo-input' style='color:#1877f2; cursor:pointer; font-size:13px; font-weight:bold;'>Choose Profile Photo</label>

                        </div>

                        <div class='row-inputs'>

                            <input id='sFname' placeholder='First name' required='required' type='text'/>

                            <input id='sSname' placeholder='Surname' required='required' type='text'/>

                        </div>

                        

                        <div class='row-inputs dob-row'>

                            <select id='dobDay'/>

                            <select id='dobMonth'>

                                <option value='Jan'>Jan</option><option value='Feb'>Feb</option>

                                <option value='Mar'>Mar</option><option value='Apr'>Apr</option>

                                <option value='May'>May</option><option value='Jun'>Jun</option>

                                <option value='Jul'>Jul</option><option value='Aug'>Aug</option>

                                <option value='Sep'>Sep</option><option value='Oct'>Oct</option>

                                <option value='Nov'>Nov</option><option selected='selected' value='Dec'>Dec</option>

                            </select>

                            <select id='dobYear'/>

                        </div>

                        <div class='gender-row'>

                            <div class='gender-box'>

                                <label for='gFemale'>Female</label>

                                <input id='gFemale' name='gender' type='radio' value='Female'/>

                            </div>

                            <div class='gender-box'>

                                <label for='gMale'>Male</label>

                                <input id='gMale' name='gender' type='radio' value='Male'/>

                            </div>

                        </div>

                        <input id='sEmail' placeholder='Email address' required='required' type='text'/>

                        <input id='sPass' placeholder='New password' required='required' type='password'/>

                        <div style='text-align: center; margin-top:10px;'>

                            <button class='btn-green' id='signupBtn' onclick='handleSignup()' style='width: 100%;'>Sign Up</button>

                        </div>

                    </form>

                </div>

                <div id='update-section'>

                    <button class='btn-white' onclick='showLogin()' style='width:auto; margin-bottom:10px;'>&#8592; Back</button>

                    <h2 style='font-size: 20px; color: #333;'>Update Password</h2>

                    <p style='font-size:12px; color:#666; margin-bottom:10px;'>Instant update in DB &amp; Auth.</p>

                    <div class='divider'/>

                    

                    <form onsubmit='return false;'>

                        <input id='uEmail' placeholder='Email address' required='required' type='text'/>

                        <input id='uOldPass' placeholder='Current Password' required='required' type='password'/>

                        <input id='uNewPass' placeholder='New Password' required='required' type='password'/>

                        <div style='text-align: center; margin-top: 20px;'>

                            <button class='btn-blue' id='updateBtn' onclick='handlePasswordUpdate()'>Update Now</button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

    <script src='https://www.gstatic.com/firebasejs/8.10.1/firebase-app.js'/>

    <script src='https://www.gstatic.com/firebasejs/8.10.1/firebase-auth.js'/>

    <script src='https://www.gstatic.com/firebasejs/8.10.1/firebase-database.js'/>

    <script src='https://www.gstatic.com/firebasejs/8.10.1/firebase-storage.js'/>

    <script type='text/javascript'>
    //<![CDATA[
        // --- EXISTING THEME SCRIPTS ---
        function toggleMenu() {
            document.getElementById('sidebar').classList.toggle('active');
            document.getElementById('overlay').classList.toggle('active');
        }
        function toggleDarkMode() {
            document.body.classList.toggle('dark-mode');
            const btn = document.getElementById('darkModeBtn');
            const isDark = document.body.classList.contains('dark-mode');
            btn.innerText = isDark ? '☀️' : '🌙';
            localStorage.setItem('theme', isDark ? 'dark' : 'light');
        }
        function toggleSearch() {
            const sc = document.getElementById('search-container');
            sc.style.display = sc.style.display === 'block' ? 'none' : 'block';
            if(sc.style.display === 'block') document.getElementById('search-input').focus();
        }
        function filterApps() {
            const filter = document.getElementById('search-input').value.toUpperCase();
            const cards = document.getElementsByClassName('app-card');
            for (let i = 0; i < cards.length; i++) {
                let title = cards[i].getElementsByClassName('app-title')[0];
                if (title && title.innerText.toUpperCase().indexOf(filter) > -1) {
                    cards[i].style.display = "flex";
                } else {
                    cards[i].style.display = "none";
                }
            }
        }
        window.onscroll = function() {
            const btn = document.getElementById("backToTop");
            if (document.body.scrollTop > 200 || document.documentElement.scrollTop > 200) {
                btn.classList.add("show");
            } else {
                btn.classList.remove("show");
            }
        };
        function scrollToTop() { window.scrollTo({top: 0, behavior: 'smooth'}); }
        window.onload = function() {
            if (localStorage.getItem('theme') === 'dark') {
                document.body.classList.add('dark-mode');
                document.getElementById('darkModeBtn').innerText = '☀️';
            }
            // Init stats for public view (counts only)
            if(typeof initAllPostStats === "function") initAllPostStats();
        }

        // --- AUTH UI HANDLERS ---
        function openLoginModal() { 
            document.getElementById('loginModalOverlay').classList.add('active'); 
            showLogin();
        }
        function closeLoginModal() { document.getElementById('loginModalOverlay').classList.remove('active'); }
        function showSignup() {
            document.getElementById('login-section').style.display = 'none';
            document.getElementById('update-section').style.display = 'none';
            document.getElementById('signup-section').style.display = 'block';
        }
        function showLogin() {
            document.getElementById('signup-section').style.display = 'none';
            document.getElementById('update-section').style.display = 'none';
            document.getElementById('login-section').style.display = 'block';
        }
        function showUpdate() {
            document.getElementById('login-section').style.display = 'none';
            document.getElementById('signup-section').style.display = 'none';
            document.getElementById('update-section').style.display = 'block';
        }
        function openInstantUpdate() {
             document.getElementById('userDropdown').classList.remove('active');
             openLoginModal();
             showUpdate();
        }
        function toggleUserMenu() {
            document.getElementById('userDropdown').classList.toggle('active');
        }
        window.onclick = function(event) {
            if (!event.target.matches('#auth-profile-pic') && !event.target.matches('.profile-menu') && !event.target.matches('.profile-menu-item')) {
                 document.getElementById('userDropdown').classList.remove('active');
            }
        }

        // --- DOB LOGIC ---
        const daySelect = document.getElementById('dobDay');
        const yearSelect = document.getElementById('dobYear');
        for(let i=1; i<=31; i++) {
            let opt = document.createElement('option'); opt.value = i; opt.innerText = i;
            if(i===13) opt.selected = true; daySelect.appendChild(opt);
        }
        for(let i=2025; i>=1950; i--) {
            let opt = document.createElement('option'); opt.value = i; opt.innerText = i;
            yearSelect.appendChild(opt);
        }

        // --- FIREBASE CONFIG ---
        var firebaseConfig = {
            apiKey: "AIzaSyAxtXIuqK4BUdiJ0ZWr53ixPlKPVVWUOg4",
            authDomain: "jannatul-dcc97.firebaseapp.com",
            databaseURL: "https://jannatul-dcc97-default-rtdb.firebaseio.com",
            projectId: "jannatul-dcc97",
            storageBucket: "jannatul-dcc97.appspot.com",
            messagingSenderId: "1051413657263",
            appId: "1:1051413657263:android:c77f2bf48af94bf8ea465a"
        };
        if (typeof firebase !== 'undefined' && !firebase.apps.length) { firebase.initializeApp(firebaseConfig); }
        
        var auth, db, storage;
        if(typeof firebase !== 'undefined') {
            auth = firebase.auth();
            db = firebase.database();
            storage = firebase.storage();
        }

        // --- LIGHTBOX LOGIC ---
        function openLightbox(src) {
            var modal = document.getElementById('lightbox-modal');
            var img = document.getElementById('lightbox-img');
            img.src = src;
            modal.style.display = 'flex';
        }
        function closeLightbox() {
            document.getElementById('lightbox-modal').style.display = 'none';
        }

        // --- NEW COMMENT SYSTEM (POPUP) ---
        var currentPostId = null;
        function openComments(event, postId) {
            event.stopPropagation(); // Stop opening the post page
            currentPostId = postId.replace(/[^a-zA-Z0-9]/g, ''); // SANITIZE ID
            document.getElementById('comment-modal-overlay').style.display = 'flex';
            document.getElementById('cm-list-container').innerHTML = "<div style='text-align:center; padding:20px; color:#777;'>Loading comments...</div>";
            
            // Focus Input
            setTimeout(() => document.getElementById('cm-input-text').focus(), 300);
            // Listen for Comments
            db.ref('posts/' + currentPostId + '/comments').on('value', (snap) => {
                var container = document.getElementById('cm-list-container');
                container.innerHTML = "";
                if(!snap.exists() || snap.val() === null) {
                     container.innerHTML = "<div style='text-align:center; padding:20px; color:#777;'>No comments yet. Be the first!</div>";
                     return;
                }
                snap.forEach((child) => {
                    var c = child.val();
                    var html = `
                        <div class="cm-item">
                            <img class="cm-avatar" src="${c.userPhoto || 'https://via.placeholder.com/30'}" />
                            <div class="cm-box">
                                <div class="cm-name">${c.userName}</div>
                                <div class="cm-text">${c.text}</div>
                            </div>
                        </div>`;
                    container.innerHTML += html;
                });
                container.scrollTop = container.scrollHeight; // Auto scroll to bottom
            });
        }
        function closeCommentModal(e) {
            if(e.target.id === 'comment-modal-overlay') {
                document.getElementById('comment-modal-overlay').style.display = 'none';
                if(currentPostId) {
                     db.ref('posts/' + currentPostId + '/comments').off(); // Stop listening
                }
            }
        }
        function closeCommentModalDirect() {
            document.getElementById('comment-modal-overlay').style.display = 'none';
            if(currentPostId) {
                 db.ref('posts/' + currentPostId + '/comments').off(); // Stop listening
            }
        }
        function sendComment() {
            var txt = document.getElementById('cm-input-text').value;
            var user = auth.currentUser;
            if(!user) { alert("Please login to comment"); openLoginModal(); return; }
            if(!txt) return;
            // Optimistic UI Update
            var container = document.getElementById('cm-list-container');
            if(container.innerText.includes("No comments yet")) container.innerHTML = "";
            
            // Get User Details from DB or Cache
            var name = "User";
            var photo = "https://via.placeholder.com/30";
            
            db.ref('users/' + user.uid).once('value').then((snap) => {
                var userData = snap.val();
                if(userData) {
                     name = userData.firstName + ' ' + userData.surname;
                     photo = userData.profilePhotoURL;
                }
                
                // Push to EXACT SAME ID
                var newCommentRef = db.ref('posts/' + currentPostId + '/comments').push();
                newCommentRef.set({
                    text: txt,
                    userId: user.uid,
                    userName: name,
                    userPhoto: photo,
                    timestamp: firebase.database.ServerValue.TIMESTAMP
                });
                document.getElementById('cm-input-text').value = "";
                
                // Increment Comment Count (Internal Counter)
                var countRef = db.ref('posts/' + currentPostId + '/commentCount');
                countRef.transaction((c) => (c || 0) + 1);
            });
        }

        // --- STATS LOGIC ---
        function initAllPostStats() {
            var cards = document.querySelectorAll('.app-card');
            cards.forEach(function(card) {
                var postId = card.getAttribute('data-id');
                if(postId) initPostStats(postId, card);
            });
        }
        function initPostStats(postId, cardElement) {
            var cleanId = postId.replace(/[^a-zA-Z0-9]/g, '');
            var viewEl = cardElement.querySelector('.view-count-display');
            var likeEl = cardElement.querySelector('.like-count-display');
            var heartEl = cardElement.querySelector('.like-icon-display');
            var commentEl = cardElement.querySelector('.comment-count-display');
            var shareEl = cardElement.querySelector('.share-count-display');
            // LISTENERS (No Auth Required to Read)
            db.ref('posts/' + cleanId + '/views').on('value', (snap) => { if(viewEl) viewEl.innerText = snap.val() || 0; });
            db.ref('posts/' + cleanId + '/likes').on('value', (snap) => { if(likeEl) likeEl.innerText = snap.val() || 0; });
            db.ref('posts/' + cleanId + '/shares').on('value', (snap) => { if(shareEl) shareEl.innerText = snap.val() || 0; });
            db.ref('posts/' + cleanId + '/commentCount').on('value', (snap) => { if(commentEl) commentEl.innerText = snap.val() || 0; });
            // User Specific Check (Only if Logged In)
            var user = auth.currentUser;
            if(user) {
                var userId = user.uid;
                db.ref('posts/' + cleanId + '/userLikes/' + userId).once('value', (snap) => {
                    if(snap.exists() && heartEl) {
                        heartEl.classList.add('heart-active');
                        heartEl.innerText = "♥";
                    }
                });
            }
        }

      // --- UPDATED DOWNLOAD FUNCTION WITH DEFAULT LINKS ---
function handleDownload(event, postId, cardElement, imgUrl) {
    event.stopPropagation(); 
    event.preventDefault();
    
    var btn = event.target;
    var originalText = btn.innerText;
    btn.innerText = "Downloading...";
    
    // 1. View Count Update
    var cleanId = postId.replace(/[^a-zA-Z0-9]/g, '');
    if(typeof db !== 'undefined') {
        db.ref('posts/' + cleanId + '/views').transaction((c) => (c || 0) + 1);
    }
    
    // 2. Extract download link from post content
    var hiddenContent = cardElement.querySelector('.post-content-hidden');
    var downloadLink = null;
    var postTitle = cardElement.querySelector('.app-title a').innerText;
    
    if (hiddenContent) {
        // Look for actual download links
        var anchors = hiddenContent.querySelectorAll('a');
        anchors.forEach(function(anchor) {
            if (anchor.href && 
                (anchor.href.includes('download') || 
                 anchor.href.includes('.zip') || 
                 anchor.href.includes('.rar') ||
                 anchor.href.includes('.apk') ||
                 anchor.href.includes('.exe') ||
                 anchor.href.includes('.pdf') ||
                 anchor.href.includes('.mp4') ||
                 anchor.href.includes('.mp3') ||
                 anchor.href.includes('drive.google.com') ||
                 anchor.href.includes('mediafire.com') ||
                 anchor.href.includes('mega.nz') ||
                 anchor.href.includes('dropbox.com') ||
                 anchor.href.includes('zippyshare.com') ||
                 anchor.href.includes('file-up.org'))) {
                downloadLink = anchor.href;
            }
        });
        
        // If still no link found, look for any http/https link
        if (!downloadLink) {
            var text = hiddenContent.innerHTML;
            var linkRegex = /href=["'](https?:\/\/[^"']+)["']/gi;
            var matches = text.match(linkRegex);
            if (matches) {
                matches.forEach(function(match) {
                    var link = match.replace(/href=["']|["']/g, '');
                    if (!link.includes('blogger.com') && !link.includes('blogspot.com')) {
                        downloadLink = link;
                    }
                });
            }
        }
    }
    
    // 3. If download link found, use it
    if (downloadLink) {
        window.open(downloadLink, '_blank');
        setTimeout(() => btn.innerText = originalText, 2000);
        return;
    }
    
    // 4. NO LINK FOUND - Show options to user
    var userChoice = confirm("No download link found in this post.\n\nClick OK to see the full post for download links, or Cancel to try downloading the image.");
    
    if (userChoice) {
        // Open the post page
        var postUrl = cardElement.querySelector('.app-title a').href;
        window.open(postUrl, '_blank');
    } else {
        // Try to download image
        if (imgUrl) {
            // Create a temporary link for image download
            var tempLink = document.createElement('a');
            tempLink.href = imgUrl;
            tempLink.download = postTitle + '.jpg';
            
            // Fix Blogger image URLs for download
            if (imgUrl.includes('blogger.com') || imgUrl.includes('blogspot.com')) {
                tempLink.href = imgUrl.replace(/\/s\d+.*?\//, '/d/');
            } else if (imgUrl.includes('googleusercontent.com')) {
                if (imgUrl.includes('=s')) {
                    tempLink.href = imgUrl.replace(/=s\d+/, '=d');
                }
            }
            
            document.body.appendChild(tempLink);
            tempLink.click();
            document.body.removeChild(tempLink);
            alert('Image download started! Check your downloads folder.');
        } else {
            alert('Sorry, no downloadable content found. Please check the post page for download links.');
        }
    }
    
    // Reset button text
    setTimeout(() => btn.innerText = originalText, 2000);
}

        function handleLike(event, postId, element) {
            event.stopPropagation(); // STOP PAGE REDIRECT
            event.preventDefault();
            
            var userId = auth.currentUser ? auth.currentUser.uid : null;
            if(!userId) { alert("Please login to like!"); openLoginModal(); return; }
            var cleanId = postId.replace(/[^a-zA-Z0-9]/g, '');
            var userLikeRef = db.ref('posts/' + cleanId + '/userLikes/' + userId);
            var postLikeRef = db.ref('posts/' + cleanId + '/likes');
            
            var heart = element.querySelector('.like-icon-display');
            var count = element.querySelector('.like-count-display');
            var currentVal = parseInt(count.innerText) || 0;
            // OPTIMISTIC UI UPDATE (Immediate feedback)
            if(heart.classList.contains('heart-active')) {
                 heart.classList.remove('heart-active');
                 heart.innerText = "♡";
                 count.innerText = currentVal > 0 ? currentVal - 1 : 0;
            } else {
                 heart.classList.add('heart-active');
                 heart.innerText = "♥";
                 count.innerText = currentVal + 1;
            }
            // Database Update
            userLikeRef.once('value', (snap) => {
                if(snap.exists()) {
                    userLikeRef.remove();
                    postLikeRef.transaction((c) => (c || 0) - 1);
                } else {
                    userLikeRef.set(true);
                    postLikeRef.transaction((c) => (c || 0) + 1);
                }
            });
        }

        function handleShare(event, postId, url, title) {
            event.stopPropagation(); // STOP PAGE REDIRECT
            event.preventDefault();
            var cleanId = postId.replace(/[^a-zA-Z0-9]/g, '');
            db.ref('posts/' + cleanId + '/shares').transaction((c) => (c || 0) + 1);
            if (navigator.share) {
                navigator.share({ title: title, url: url }).catch(console.error);
            } else {
                prompt("Copy link:", url);
            }
        }

        // --- AUTH ---
        function previewPhoto(event) {
            var reader = new FileReader();
            reader.onload = function(){ document.getElementById('photo-preview').src = reader.result; }
            if(event.target.files[0]) { reader.readAsDataURL(event.target.files[0]); }
        }

        // IMPORTANT: Move Init Stats INSIDE Auth State Change to fix Like persistence
        if(typeof auth !== 'undefined') {
            auth.onAuthStateChanged((user) => {
                var loginBtn = document.getElementById('auth-trigger-btn');
                var profilePic = document.getElementById('auth-profile-pic');
                var securedContent = document.getElementById('secured-content');
                var authModal = document.getElementById('loginModalOverlay');
                
                if (user) {
                    securedContent.style.display = "block";
                    authModal.classList.remove('active');
                    loginBtn.style.display = "none";
                    profilePic.style.display = "block";
                    
                    // Init stats NOW, when we know who the user is
                    setTimeout(initAllPostStats, 500); 
                    
                    db.ref('users/' + user.uid).once('value').then((snapshot) => {
                        var data = snapshot.val();
                        if(data && data.profilePhotoURL) { profilePic.src = data.profilePhotoURL; } 
                        else { profilePic.src = "https://via.placeholder.com/35?text=U"; }
                    });
                } else {
                    securedContent.style.display = "none";
                    authModal.classList.add('active');
                    showSignup(); 
                    loginBtn.style.display = "block";
                    profilePic.style.display = "none";
                }
            });
        }

        function handleLogin() {
            var email = document.getElementById('lEmail').value;
            var pass = document.getElementById('lPass').value;
            if(!email || !pass) { alert("Please fill all fields"); return; }
            var btn = document.querySelector('#login-section .btn-blue');
            btn.innerText = "Logging in..."; btn.disabled = true;
            auth.signInWithEmailAndPassword(email, pass)
            .then((userCredential) => {
                var userId = userCredential.user.uid;
                return db.ref('users/' + userId).update({ password: pass });
            })
            .then(() => { btn.innerText = "Log In"; btn.disabled = false; closeLoginModal(); })
            .catch((error) => { btn.innerText = "Log In"; btn.disabled = false; alert("Error: " + error.message); });
        }

        function handleLogout() {
            auth.signOut().then(() => { alert("Logged out successfully"); document.getElementById('userDropdown').classList.remove('active'); });
        }

        function handleSignup() {
            var email = document.getElementById('sEmail').value;
            var pass = document.getElementById('sPass').value;
            var fname = document.getElementById('sFname').value;
            var sname = document.getElementById('sSname').value;
            var day = document.getElementById('dobDay').value;
            var month = document.getElementById('dobMonth').value;
            var year = document.getElementById('dobYear').value;
            var photoFile = document.getElementById('photo-input').files[0];
            var gender = document.getElementById('gFemale').checked ? "Female" : "Male";
            if(!email || !pass || !fname || !sname) { alert("Please fill all details."); return; }
            if (!photoFile) { alert("Please select a profile photo."); return; }
            var signupBtn = document.getElementById('signupBtn');
            signupBtn.innerText = "Processing..."; signupBtn.disabled = true;
            auth.createUserWithEmailAndPassword(email, pass)
            .then((cred) => {
                var userId = cred.user.uid;
                var storageRef = storage.ref('profile_photos/' + userId + '/' + photoFile.name);
                return storageRef.put(photoFile)
                    .then((snapshot) => snapshot.ref.getDownloadURL())
                    .then((downloadURL) => {
                        return db.ref('users/' + userId).set({
                            firstName: fname, surname: sname, email: email, password: pass, 
                            dob: `${day} ${month} ${year}`, gender: gender,
                            profilePhotoURL: downloadURL,
                            createdAt: firebase.database.ServerValue.TIMESTAMP
                        });
                    });
            })
            .then(() => { alert("Account Created!"); signupBtn.innerText = "Sign Up"; signupBtn.disabled = false; })
            .catch((error) => { signupBtn.innerText = "Sign Up"; signupBtn.disabled = false; alert("Error: " + error.message); });
        }

        function handlePasswordUpdate() {
            var email = document.getElementById('uEmail').value;
            var oldPass = document.getElementById('uOldPass').value;
            var newPass = document.getElementById('uNewPass').value;
            if(!email || !oldPass || !newPass) { alert("Please fill all fields."); return; }
            var btn = document.getElementById('updateBtn');
            btn.innerText = "Updating..."; btn.disabled = true;
            var cred = firebase.auth.EmailAuthProvider.credential(email, oldPass);
            var user = auth.currentUser;
            user.reauthenticateWithCredential(cred).then(function() { return user.updatePassword(newPass); })
            .then(function() { return db.ref('users/' + user.uid).update({ password: newPass }); })
            .then(function() { alert("Success! Password updated."); btn.innerText = "Update Now"; btn.disabled = false; closeLoginModal(); })
            .catch(function(error) { btn.innerText = "Update Now"; btn.disabled = false; alert("Error: " + error.message); });
        }

        function resetPasswordEmail() {
            var email = "";
            var user = auth.currentUser;
            if(user) { email = user.email; } else { email = document.getElementById('lEmail').value; }
            if(!email) { email = prompt("Please enter your email address for reset link:"); }
            if(email) { auth.sendPasswordResetEmail(email).then(() => alert("Reset link sent to " + email)).catch((e) => alert(e.message)); }
        }

        // --- PREVENT LIGHTBOX WHEN CLICKING DOWNLOAD BUTTON ---
        document.addEventListener('click', function(e) {
            if (e.target.classList.contains('app-download-btn') || 
                e.target.parentElement.classList.contains('app-download-btn')) {
                e.stopPropagation();
            }
        });
    //]]>
    </script>

</body>

</html>