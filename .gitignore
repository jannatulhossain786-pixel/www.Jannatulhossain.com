<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE html>
<html b:version='2' class='v2' expr:dir='data:blog.languageDirection' xmlns='http://www.w3.org/1999/xhtml' xmlns:b='http://www.google.com/2005/gml/b' xmlns:data='http://www.google.com/2005/gml/data' xmlns:expr='http://www.google.com/2005/gml/expr'>

<head> 

    <meta content='width=device-width, initial-scale=1.0' name='viewport'/>

    <b:include data='blog' name='all-head-content'/>

    <title><data:blog.pageTitle/></title>

    <link href='https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&amp;display=swap' rel='stylesheet'/>

    <b:skin><![CDATA[

        /* --- CSS VARIABLES & STYLING --- */

        :root {

            --primary-color: #ff4757;

            --bg-color: #f5f5f5;

            --card-bg: #ffffff;

            --text-dark: #333;

            --text-light: #777;

            --header-bg: #ffffff;

            --border-color: #eee;

            --sidebar-bg: #ffffff;

            --footer-bg: #ffffff;

        }

        /* DARK MODE VARIABLES */

        body.dark-mode {

            --bg-color: #121212;

            --card-bg: #1e1e1e;

            --text-dark: #e0e0e0;

            --text-light: #aaa;

            --header-bg: #1e1e1e;

            --border-color: #333;

            --sidebar-bg: #1e1e1e;

            --footer-bg: #1e1e1e;

        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Poppins', sans-serif; transition: background 0.3s, color 0.3s; }

        body { background-color: var(--bg-color); color: var(--text-dark); overflow-x: hidden; }

        a { text-decoration: none; color: inherit; }

        /* Header */

        header {

            background: var(--header-bg);

            padding: 15px 20px;

            display: flex;

            justify-content: space-between;

            align-items: center;

            box-shadow: 0 2px 5px rgba(0,0,0,0.1);

            position: sticky;

            top: 0;

            z-index: 1000;

        }

        .menu-icon { font-size: 24px; cursor: pointer; color: var(--text-dark); }

        

        /* HEADER LOGO WITH GRADIENT (Purple to Pink) */

        .logo-text, .logo-text a, .header-inner h1 a { 

            font-size: 24px !important; 

            font-weight: 800 !important; 

            background: linear-gradient(to right, #9B4F96, #FF4B5C) !important;

            -webkit-background-clip: text !important;

            -webkit-text-fill-color: transparent !important;

            background-clip: text !important;

            letter-spacing: 1px; 

            text-decoration: none !important;

        }

        

        .header-icons {

            display: flex;

            align-items: center;

        }

        .header-icons span {

            margin-left: 15px;

            font-size: 20px;

            cursor: pointer;

            color: var(--text-dark);

            user-select: none;

        }

        /* Search Bar Overlay */

        #search-container {

            display: none;

            background: var(--header-bg);

            padding: 10px 20px;

            border-bottom: 1px solid var(--border-color);

            animation: slideDown 0.3s ease;

        }

        #search-input {

            width: 100%;

            padding: 10px;

            border-radius: 8px;

            border: 1px solid var(--border-color);

            background: var(--bg-color);

            color: var(--text-dark);

            outline: none;

        }

        @keyframes slideDown { from {transform: translateY(-20px); opacity: 0;} to {transform: translateY(0); opacity: 1;} }

        /* Sidebar Menu */

        .sidebar {

            position: fixed;

            top: 0;

            left: -280px;

            width: 280px;

            height: 100%;

            background: var(--sidebar-bg);

            box-shadow: 2px 0 10px rgba(0,0,0,0.2);

            z-index: 2000;

            transition: left 0.3s ease;

            padding: 20px;

            overflow-y: auto;

        }

        .sidebar.active { left: 0; }

        .sidebar-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; border-bottom: 1px solid var(--border-color); padding-bottom: 10px; }

        .close-btn { font-size: 24px; cursor: pointer; color: var(--text-dark); }

        

        /* Blogger LinkList Styling */

        .sidebar .widget-content ul { list-style: none; padding: 0; }

        .sidebar .widget-content li { padding: 0; }

        .sidebar .widget-content li a {

            padding: 12px 0;

            border-bottom: 1px solid var(--border-color);

            color: var(--text-dark);

            font-weight: 500;

            cursor: pointer;

            display: block;

        }

        .sidebar .widget-content li a:hover { color: var(--primary-color); }

        

        .overlay {

            position: fixed;

            top: 0; left: 0; width: 100%; height: 100%;

            background: rgba(0,0,0,0.5);

            z-index: 1500;

            display: none;

        }

        .overlay.active { display: block; }

        /* Main Container */

        .container { max-width: 1200px; margin: 20px auto; padding: 0 15px; min-height: 60vh; }

        .section-title {

            font-size: 14px; font-weight: 700; color: var(--text-dark);

            text-transform: uppercase; border-bottom: 2px solid var(--primary-color);

            display: inline-block; margin-bottom: 15px; padding-bottom: 5px;

        }

        /* Grid */

        .app-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 15px; }

        .app-card {

            background: var(--card-bg); border-radius: 12px; padding: 15px;

            box-shadow: 0 4px 6px rgba(0,0,0,0.05); position: relative;

            display: flex; flex-direction: column; align-items: center; text-align: center;

        }

        .app-card:hover { transform: translateY(-3px); }

        

        /* Post Thumbnails */

        .app-icon-img {

            width: 70px; height: 70px; border-radius: 15px; margin-bottom: 10px;

            overflow: hidden; display: flex; align-items: center; justify-content: center;

            cursor: pointer;

        }

        .app-icon-img img { width: 100%; height: 100%; object-fit: cover; }

        .icon-placeholder { background: #4fabff; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 30px; color: white;}

        .app-title { font-size: 14px; font-weight: 600; color: var(--text-dark); margin-bottom: 5px; height: 38px; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;}

        .app-meta { font-size: 10px; color: var(--primary-color); font-weight: 500; }

        .app-date { font-size: 10px; color: var(--text-light); }

        /* DOWNLOAD BUTTON STYLE - FIXED */

        .app-download-btn {

            display: block;

            margin-top: 10px;

            padding: 8px 0;

            background: var(--primary-color);

            color: white !important;

            text-align: center;

            border-radius: 6px;

            font-size: 12px;

            font-weight: 600;

            width: 100%;

            cursor: pointer;

            text-transform: uppercase;

            position: relative;

            z-index: 10;

        }

        .app-download-btn:hover { opacity: 0.9; box-shadow: 0 3px 8px rgba(255, 71, 87, 0.3); }

        /* --- SOCIAL STATS ROW --- */

        .social-stats-row {

            display: flex;

            justify-content: space-between;

            align-items: center;

            width: 100%;

            margin-top: 12px;

            padding-top: 8px;

            border-top: 1px solid var(--border-color);

            font-size: 11px;

            color: var(--text-light);

        }

        .stat-item {

            display: flex;

            align-items: center;

            gap: 3px;

            cursor: pointer;

            padding: 5px; /* Bigger tap area */

        }

        .stat-item span { font-weight: 600; }

        .stat-item:hover { color: var(--primary-color); }

        .heart-active { color: #e84393; font-weight:bold; }

        /* LIGHTBOX STYLES */

        #lightbox-modal {

            display: none;

            position: fixed;

            z-index: 10000;

            padding: 20px;

            left: 0;

            top: 0;

            width: 100%;

            height: 100%;

            background-color: rgba(0, 0, 0, 0.9);

            justify-content: center;

            align-items: center;

            flex-direction: column;

        }

        #lightbox-img {

            max-width: 90%;

            max-height: 80vh;

            border-radius: 8px;

            box-shadow: 0 0 20px rgba(255,255,255,0.1);

            animation: zoomIn 0.3s;

        }

        @keyframes zoomIn { from {transform:scale(0.8); opacity:0;} to {transform:scale(1); opacity:1;} }

        .lightbox-close {

            position: absolute;

            top: 20px;

            right: 30px;

            color: #f1f1f1;

            font-size: 40px;

            font-weight: bold;

            cursor: pointer;

        }

        /* --- COMMENT MODAL (POPUP) STYLES --- */

        #comment-modal-overlay {

            position: fixed; bottom: 0; left: 0; width: 100%; height: 100%;

            background: rgba(0,0,0,0.5); z-index: 9000; display: none;

            align-items: flex-end; /* Slide up from bottom */

        }

        #comment-modal-content {

            background: var(--card-bg);

            width: 100%; max-width: 600px; margin: 0 auto;

            border-radius: 15px 15px 0 0;

            padding: 15px;

            max-height: 80vh;

            display: flex; flex-direction: column;

            animation: slideUp 0.3s ease-out;

            box-shadow: 0 -5px 20px rgba(0,0,0,0.2);

        }

        @keyframes slideUp { from{transform:translateY(100%);} to{transform:translateY(0);} }

        

        .cm-header { display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-color); padding-bottom: 10px; margin-bottom: 10px; }

        .cm-title { font-weight: 700; color: var(--text-dark); }

        .cm-close { font-size: 24px; cursor: pointer; color: var(--text-light); }

        

        .cm-list { flex: 1; overflow-y: auto; margin-bottom: 10px; min-height: 200px; }

        .cm-item { display: flex; gap: 10px; margin-bottom: 15px; }

        .cm-avatar { width: 30px; height: 30px; border-radius: 50%; object-fit: cover; }

        .cm-box { background: var(--bg-color); padding: 8px 12px; border-radius: 12px; flex: 1; }

        .cm-name { font-size: 11px; font-weight: 700; color: var(--text-dark); margin-bottom: 2px; }

        .cm-text { font-size: 13px; color: var(--text-dark); }

        

        .cm-input-area { display: flex; gap: 10px; align-items: center; border-top: 1px solid var(--border-color); padding-top: 10px; }

        .cm-input { flex: 1; padding: 10px; border: 1px solid var(--border-color); border-radius: 20px; background: var(--bg-color); color: var(--text-dark); outline: none; }

        .cm-send { color: var(--primary-color); font-weight: 600; cursor: pointer; padding: 5px 10px; }

        /* Subscribe Box */

        .subscribe-box {

            background: var(--card-bg);

            border-radius: 12px; padding: 30px 20px;

            text-align: center; margin: 40px auto;

            max-width: 600px; box-shadow: 0 5px 15px rgba(0,0,0,0.05);

            position: relative; overflow: hidden;

        }

        .subscribe-box::before {

            content: ''; position: absolute; top: -50px; right: -50px;

            width: 100px; height: 100px; background: rgba(255, 71, 87, 0.1);

            border-radius: 50%;

        }

        .bell-icon-circle {

            width: 50px; height: 50px; background: #fff; border-radius: 50%;

            box-shadow: 0 5px 15px rgba(0,0,0,0.1); margin: 0 auto 15px;

            display: flex; align-items: center; justify-content: center;

            font-size: 24px; color: var(--primary-color);

        }

        .sub-title { font-weight: 700; font-size: 18px; margin-bottom: 5px; color: var(--text-dark); }

        .sub-desc { font-size: 12px; color: var(--text-light); margin-bottom: 20px; }

        .sub-input {

            width: 100%; padding: 12px; border: 1px solid var(--border-color);

            border-radius: 6px; background: var(--bg-color); color: var(--text-dark);

            margin-bottom: 15px; outline: none;

        }

        .sub-btn {

            width: 100%; padding: 12px; background: var(--primary-color);

            color: white; border: none; border-radius: 6px; font-weight: 600;

            cursor: pointer; box-shadow: 0 4px 10px rgba(255, 71, 87, 0.3);

        }

        /* Category Cloud (Label Widget) */

        .category-section {

            background: var(--card-bg); padding: 20px;

            margin-bottom: 30px; border-radius: 12px;

        }

        .tags-container { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 15px; }

        .Label a {

            padding: 5px 12px;

            border: 1px solid #ffcccc;

            color: #d63031; 

            font-size: 12px;

            border-radius: 6px;

            cursor: pointer;

            background: #fff;

            transition: 0.2s;

            display: inline-block;

        }

        body.dark-mode .Label a {

            background: #2d2d2d; border-color: #444; color: #ff6b81;

        }

        .Label a:hover {

            background: var(--primary-color); color: white; border-color: var(--primary-color);

        }

        /* Footer */

        footer {

            background: var(--footer-bg);

            padding: 40px 20px 20px;

            text-align: center;

            margin-top: 40px;

            border-top: 1px solid var(--border-color);

        }

        .footer-logo {

            font-size: 32px; font-weight: 800;

            background: -webkit-linear-gradient(#d63031, #9b59b6);

            -webkit-background-clip: text;

            -webkit-text-fill-color: transparent;

            margin-bottom: 10px; display: inline-block;

        }

        .footer-about-title { font-weight: 700; margin-bottom: 10px; color: var(--text-dark); }

        .footer-desc {

            font-size: 12px; color: var(--text-light); max-width: 600px;

            margin: 0 auto 20px; line-height: 1.6;

        }

        .social-icons { margin-bottom: 30px; }

        .social-icon {

            display: inline-flex; width: 35px; height: 35px;

            background: #eee; border-radius: 50%;

            align-items: center; justify-content: center;

            margin: 0 5px; cursor: pointer; font-size: 14px;

            color: #555;

        }

        .social-icon:hover { background: var(--primary-color); color: white; }

        .footer-links {

            display: flex; flex-wrap: wrap; justify-content: center; gap: 15px;

            font-size: 13px; font-weight: 600; color: var(--text-dark);

            margin-bottom: 20px;

        }

        .copyright { font-size: 12px; color: var(--text-light); border-top: 1px solid var(--border-color); padding-top: 20px; }

        /* Back to Top */

        #backToTop {

            position: fixed; bottom: 20px; right: 20px;

            width: 45px; height: 45px; background: var(--primary-color);

            color: white; border-radius: 8px; display: flex;

            align-items: center; justify-content: center;

            cursor: pointer; opacity: 0; pointer-events: none;

            transition: 0.3s; z-index: 999; font-size: 20px;

            box-shadow: 0 4px 10px rgba(0,0,0,0.2);

        }

        #backToTop.show { opacity: 1; pointer-events: auto; }

        

        /* Blogger UI overrides */

        .widget { margin-bottom: 0; }

        .navbar { display: none !important; }

        /* --- LOGIN & PROFILE STYLES --- */

        #auth-trigger-btn {

            background: var(--primary-color); color: white;

            padding: 5px 12px; border-radius: 20px; font-size: 12px;

            font-weight: 600; margin-left: 10px; cursor: pointer;

        }

        #auth-profile-pic {

            width: 35px; height: 35px; border-radius: 50%;

            margin-left: 10px; cursor: pointer; object-fit: cover;

            border: 2px solid var(--primary-color); display: none;

        }

        

        /* Modal for Login */

        .auth-overlay-modal {

            position: fixed; top: 0; left: 0; width: 100%; height: 100%;

            background: rgba(0,0,0,0.8); z-index: 9999; display: none;

            justify-content: center; align-items: center; overflow-y: auto;

        }

        .auth-overlay-modal.active { display: flex; }

        

        /* Profile Dropdown Menu */

        .profile-menu {

            position: absolute; top: 60px; right: 20px;

            background: var(--card-bg); box-shadow: 0 5px 15px rgba(0,0,0,0.2);

            border-radius: 8px; width: 200px; display: none; z-index: 2001;

            padding: 10px 0;

        }

        .profile-menu.active { display: block; }

        .profile-menu-item {

            padding: 10px 15px; font-size: 13px; color: var(--text-dark);

            cursor: pointer; border-bottom: 1px solid var(--border-color);

            display: block;

        }

        .profile-menu-item:hover { background: var(--bg-color); color: var(--primary-color); }

        .profile-menu-item:last-child { border: none; }

        /* Integrated Login CSS */

        #auth-module .card { 

            background: #fff; border-radius: 8px; width: 350px; padding: 20px; 

            text-align: center; max-height: 90vh; overflow-y: auto; position: relative;

        }

        #auth-module h1 { color: #1877f2; font-size: 30px; margin-bottom: 20px; }

        #auth-module input, #auth-module select {

            width: 100%; padding: 12px; margin-bottom: 10px; border: 1px solid #ddd; border-radius: 6px; box-sizing: border-box; color: #333;

        }

        #auth-module .btn-blue { background: #1877f2; color: white; border: none; width: 100%; padding: 10px; border-radius: 6px; font-size: 16px; font-weight: bold; cursor: pointer; margin-bottom: 10px; }

        #auth-module .btn-green { background: #42b72a; color: white; border: none; padding: 10px 20px; border-radius: 6px; font-size: 15px; font-weight: bold; cursor: pointer; }

        #auth-module .btn-white { background: #fff; color: #333; border: 1px solid #ccc; padding: 8px; border-radius: 6px; cursor: pointer; margin-top: 5px; font-size: 13px; width: 100%; }

        #auth-module .forgot-link { color: #1877f2; font-size: 12px; cursor: pointer; display: block; margin: 10px 0; }

        #auth-module .divider { border-bottom: 1px solid #ddd; margin: 15px 0; }

        #auth-module #signup-section, #auth-module #update-section { display: none; text-align: left; }

        

        .row-inputs { display: flex; gap: 5px; }

        .gender-row { display: flex; gap: 5px; margin-bottom: 10px; }

        .gender-box { border: 1px solid #ddd; padding: 5px; flex: 1; display: flex; align-items: center; font-size: 12px; border-radius: 4px; color: #333;}

        .gender-box input { width: auto; margin: 0 0 0 5px; }

        #photo-preview { width: 80px; height: 80px; border-radius: 50%; display: block; margin: 0 auto 10px; border: 2px solid #ddd; object-fit: cover;}

    ]]></b:skin>

</head>

<body>

    <div id='lightbox-modal' onclick='closeLightbox()'>

        <span class='lightbox-close'>&#215;</span>

        <img alt='Zoomed' id='lightbox-img' src=''/>

        <div style='color:white; margin-top:10px; font-size:14px;'>Tap outside to close</div>

    </div>

    <div id='comment-modal-overlay' onclick='closeCommentModal(event)'>

        <div id='comment-modal-content' onclick='event.stopPropagation()'>

            <div class='cm-header'>

                <span class='cm-title'>Comments</span>

                <span class='cm-close' onclick='closeCommentModalDirect()'>&#215;</span>

            </div>

            <div class='cm-list' id='cm-list-container'>

                <div style='text-align:center; padding:20px; color:#777;'>Loading comments...</div>

            </div>

            <div class='cm-input-area'>

                <input class='cm-input' id='cm-input-text' placeholder='Write a comment...' type='text'/>

                <div class='cm-send' onclick='sendComment()'>&#10148;</div>

            </div>

        </div>

    </div>

    <div id='secured-content'>

    <div class='overlay' id='overlay' onclick='toggleMenu()'/>

    

    <div class='sidebar' id='sidebar'>

        <div class='sidebar-header'>

            <span class='logo-text'><data:blog.title/></span>

            <span class='close-btn' onclick='toggleMenu()'>&#215;</span>

        </div>

        <b:section class='sidebar-menu' id='Sidebar-Menu' showaddelement='yes'>
          <b:widget id='LinkList1' locked='false' title='Menu' type='LinkList' version='1'>
            <b:widget-settings>
              <b:widget-setting name='sorting'>NONE</b:widget-setting>
              <b:widget-setting name='text-1'>Apps</b:widget-setting>
              <b:widget-setting name='link-1'>/search/label/Apps</b:widget-setting>
              <b:widget-setting name='text-0'>Home</b:widget-setting>
              <b:widget-setting name='link-0'>/</b:widget-setting>
            </b:widget-settings>
            <b:includable id='main'>

                  <div class='widget-content'>

                    <ul>

                      <b:loop values='data:links' var='link'>

                        <li><a expr:href='data:link.target'><data:link.name/></a></li>

                      </b:loop>

                    </ul>

                  </div>

                </b:includable>
          </b:widget>
          <b:widget id='Header1' locked='false' title='𝙅𝘼𝙉𝙉𝘼𝙏𝙐𝙇 𝙃𝙊𝙎𝙎𝘼𝙄𝙉 (Header)' type='Header' version='1'>
            <b:widget-settings>
              <b:widget-setting name='displayUrl'/>
              <b:widget-setting name='displayHeight'>0</b:widget-setting>
              <b:widget-setting name='sectionWidth'>-1</b:widget-setting>
              <b:widget-setting name='useImage'>false</b:widget-setting>
              <b:widget-setting name='shrinkToFit'>false</b:widget-setting>
              <b:widget-setting name='imagePlacement'>BEHIND</b:widget-setting>
              <b:widget-setting name='displayWidth'>0</b:widget-setting>
            </b:widget-settings>
            <b:includable id='main'>

                <div id='header-inner'>

                  <div class='titlewrapper'>

                    <h1 class='title'>

                      <b:include name='title'/>

                    </h1>

                  </div>

                  <b:include name='description'/>

                </div>

            </b:includable>
            <b:includable id='description'>

              <div class='descriptionwrapper'>

                <p class='description'><span><data:description/></span></p>

              </div>

            </b:includable>
            <b:includable id='title'>

              <b:tag cond='data:blog.url != data:blog.homepageUrl' expr:href='data:blog.homepageUrl' name='a'>

                <div class='logo-text'><data:title/></div>

              </b:tag>

            </b:includable>
          </b:widget>
        </b:section>

    </div>

    <header>

        <div class='menu-icon' onclick='toggleMenu()'>&#9776;</div>

        <div class='logo-text'><data:blog.title/></div>

        <div class='header-icons'>

            <span id='darkModeBtn' onclick='toggleDarkMode()'>🌙</span>

            <span onclick='toggleSearch()'>🔍</span>

            

            <div id='auth-trigger-btn' onclick='openLoginModal()'>Login</div>

            <img alt='Profile' id='auth-profile-pic' onclick='toggleUserMenu()' src=''/>

        </div>

    </header>

    

    <div class='profile-menu' id='userDropdown'>

        <span class='profile-menu-item' onclick='resetPasswordEmail()'>Forget Password</span>

        <span class='profile-menu-item' onclick='openInstantUpdate()'>Instant Password Update</span>

        <span class='profile-menu-item' onclick='handleLogout()' style='color:red;'>Logout</span>

    </div>

    <div id='search-container'>

        <input id='search-input' onkeyup='filterApps()' placeholder='Search apps...' type='text'/>

    </div>

    <div class='container'>

        <div class='section-title'>LATEST POSTS</div>

        <b:section class='main' id='Main' showaddelement='yes'>
          <b:widget id='Blog1' locked='true' title='Blog Posts' type='Blog' version='1'>
            <b:widget-settings>
              <b:widget-setting name='showDateHeader'>true</b:widget-setting>
              <b:widget-setting name='style.textcolor'>#ffffff</b:widget-setting>
              <b:widget-setting name='showShareButtons'>true</b:widget-setting>
              <b:widget-setting name='authorLabel'>By</b:widget-setting>
              <b:widget-setting name='showCommentLink'>true</b:widget-setting>
              <b:widget-setting name='style.urlcolor'>#ffffff</b:widget-setting>
              <b:widget-setting name='showAuthor'>true</b:widget-setting>
              <b:widget-setting name='style.linkcolor'>#ffffff</b:widget-setting>
              <b:widget-setting name='style.unittype'>TextAndImage</b:widget-setting>
              <b:widget-setting name='style.bgcolor'>#ffffff</b:widget-setting>
              <b:widget-setting name='timestampLabel'>on</b:widget-setting>
              <b:widget-setting name='reactionsLabel'/>
              <b:widget-setting name='showAuthorProfile'>true</b:widget-setting>
              <b:widget-setting name='style.layout'>1x1</b:widget-setting>
              <b:widget-setting name='showLabels'>true</b:widget-setting>
              <b:widget-setting name='showLocation'>true</b:widget-setting>
              <b:widget-setting name='showTimestamp'>true</b:widget-setting>
              <b:widget-setting name='postsPerAd'>1</b:widget-setting>
              <b:widget-setting name='showBacklinks'>false</b:widget-setting>
              <b:widget-setting name='style.bordercolor'>#ffffff</b:widget-setting>
              <b:widget-setting name='showInlineAds'>false</b:widget-setting>
              <b:widget-setting name='showReactions'>false</b:widget-setting>
            </b:widget-settings>
            <b:includable id='main' var='top'>

                    <div class='app-grid' id='appGrid'>

                        <b:loop values='data:posts' var='post'>

                            <div class='app-card' expr:data-id='data:post.id'>

                                <div class='app-icon-img' expr:onclick='&quot;openLightbox(\&quot;&quot; + data:post.firstImageUrl + &quot;\&quot;)&quot;'>

                                    <b:if cond='data:post.firstImageUrl'>

                                        <img alt='App Icon' expr:src='data:post.firstImageUrl'/>

                                    <b:else/>

                                        <div class='icon-placeholder'>📱</div>

                                    </b:if>

                                </div>

                                

                                <div class='post-content-hidden' style='display:none;'><data:post.body/></div>

                                <h3 class='app-title'><a expr:href='data:post.url'><data:post.title/></a></h3>

                                <div class='app-meta'><data:post.author/></div>

                                

                                <div class='app-download-btn' expr:onclick='&quot;handleDownload(event, \&quot;&quot; + data:post.id + &quot;\&quot;, this.parentNode, \&quot;&quot; + data:post.firstImageUrl + &quot;\&quot;)&quot;'>&#11015; DOWNLOAD</div>

                                

                                <div class='social-stats-row'>

                                    <div class='stat-item' title='Views'>

                                        👁 <span class='view-count-display'>0</span>

                                    </div>

                                    <div class='stat-item' expr:onclick='&quot;handleLike(event, \&quot;&quot; + data:post.id + &quot;\&quot;, this)&quot;' title='Like'>

                                        <span class='like-icon-display'>&#9825;</span> 

                                        <span class='like-count-display'>0</span>

                                    </div>

                                    <div class='stat-item' expr:onclick='&quot;openComments(event, \&quot;&quot; + data:post.id + &quot;\&quot;)&quot;' title='Comments'>

                                        💬 <span class='comment-count-display'><data:post.numComments/></span>

                                    </div>

                                    <div class='stat-item' expr:onclick='&quot;handleShare(event, \&quot;&quot; + data:post.id + &quot;\&quot;, \&quot;&quot; + data:post.url + &quot;\&quot;, \&quot;&quot; + data:post.title + &quot;\&quot;)&quot;' title='Share'>

                                        &#10150; <span class='share-count-display'>0</span>

                                    </div>

                                </div>

                            </div>

                        </b:loop>

                    </div>

                    

                    <div style='text-align:center; margin-top:20px;'>

                        <b:if cond='data:newerPageUrl'>

                            <a class='tag' expr:href='data:newerPageUrl'>Previous</a>

                        </b:if>

                        <b:if cond='data:olderPageUrl'>

                            <a class='tag' expr:href='data:olderPageUrl'>Next Page</a>

                        </b:if>

                    </div>

                </b:includable>
            <b:includable id='backlinkDeleteIcon' var='backlink'/>
            <b:includable id='backlinks' var='post'/>
            <b:includable id='comment-form' var='post'/>
            <b:includable id='commentDeleteIcon' var='comment'/>
            <b:includable id='comment_count_picker' var='post'/>
            <b:includable id='comment_picker' var='post'/>
            <b:includable id='comments' var='post'/>
            <b:includable id='feedLinks'/>
            <b:includable id='feedLinksBody' var='links'/>
